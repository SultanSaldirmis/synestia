rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function onlyUserCounterFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['followersCount', 'followingCount', 'collectionsCount']);
    }

    function onlyPostSocialCounters() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['likesCount', 'commentCount']);
    }

    function isPostAuthor(postId) {
      return isSignedIn()
        && request.auth.uid == get(/databases/$(database)/documents/posts/$(postId)).data.authorUid;
    }

    // Kullanıcı profili (kök belge)
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || (isSignedIn() && onlyUserCounterFields());
      allow delete: if isOwner(userId);

      // Takipçiler — takip eden kullanıcı kendi kaydını oluşturur; profil sahibi istek kabul ederken de oluşturabilir
      match /followers/{followerId} {
        allow read: if isSignedIn();
        allow create, delete: if isSignedIn() && (
          request.auth.uid == followerId
          || (isOwner(userId) && exists(/databases/$(database)/documents/users/$(userId)/followRequests/$(followerId)))
        );
      }

      // Takip edilenler — profil sahibi veya istek kabul eden (targetId) oluşturabilir
      match /following/{targetId} {
        allow read: if isSignedIn();
        allow create, delete: if isOwner(userId) || (
          isSignedIn()
          && request.auth.uid == targetId
          && exists(/databases/$(database)/documents/users/$(request.auth.uid)/followRequests/$(userId))
        );
      }

      // Takip istekleri — istek gönderen oluşturur; profil sahibi veya gönderen siler
      match /followRequests/{fromUid} {
        allow read: if isOwner(userId) || (isSignedIn() && request.auth.uid == fromUid);
        allow create: if isSignedIn() && request.auth.uid == fromUid;
        allow delete: if isOwner(userId) || (isSignedIn() && request.auth.uid == fromUid);
      }

      // Bildirimler — herhangi giriş yapmış kullanıcı oluşturabilir; okuma/güncelleme sahibe
      match /notifications/{notifId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if isSignedIn();
      }

      // Beğeniler — profil sahibi yazar; post sahibi silme sırasında aynayı temizleyebilir
      match /likes/{postId} {
        allow read: if isSignedIn();
        allow create, update: if isOwner(userId);
        allow delete: if isOwner(userId) || (
          isSignedIn()
          && exists(/databases/$(database)/documents/posts/$(postId))
          && request.auth.uid == get(/databases/$(database)/documents/posts/$(postId)).data.authorUid
        );
      }

      // Koleksiyonlar — okuma herkese; yazma sahibe
      match /collections/{collectionId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }
    }

    // Postlar
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.auth.uid == request.resource.data.authorUid;
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.authorUid
        || onlyPostSocialCounters()
      );
      allow delete: if isSignedIn()
                    && request.auth.uid == resource.data.authorUid;

      match /likes/{uid} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && request.auth.uid == uid;
        allow delete: if isSignedIn() && (request.auth.uid == uid || isPostAuthor(postId));
      }

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
                      && exists(/databases/$(database)/documents/posts/$(postId));
        allow delete: if isSignedIn() && (
          request.auth.uid == resource.data.authorUid
          || (
            resource.data.keys().hasAny(['parentId'])
            && resource.data.parentId is string
            && resource.data.parentId != ''
            && get(/databases/$(database)/documents/posts/$(postId)/comments/$(resource.data.parentId)).data.authorUid == request.auth.uid
          )
          || isPostAuthor(postId)
        );
      }
    }

    // Katalog kitap puanlamaları
    match /bookRatings/{itemId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();

      match /ratings/{userId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Katalog film puanlamaları
    match /movieRatings/{itemId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();

      match /ratings/{userId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Genel katalog yorumları
    match /globalContentComments/{itemId}/comments/{commentId} {
      allow read, create: if isSignedIn();
      allow delete: if isSignedIn()
                    && request.auth.uid == resource.data.authorUid;
    }

    // Gönderi raporları — giriş yapmış kullanıcı kendi adına rapor oluşturabilir
    match /reports/{reportId} {
      allow create: if isSignedIn()
                    && request.auth.uid == request.resource.data.reporterUid;
      allow read, update, delete: if false;
    }
  }
}
