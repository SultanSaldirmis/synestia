rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function onlyUserCounterFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['followersCount', 'followingCount', 'collectionsCount']);
    }

    function onlyPostSocialCounters() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['likesCount', 'commentCount']);
    }

    // Kullanıcı profili (kök belge)
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || (isSignedIn() && onlyUserCounterFields());
      allow delete: if isOwner(userId);

      // Takipçiler — takip eden kullanıcı kendi kaydını oluşturur/siler
      match /followers/{followerId} {
        allow read: if isSignedIn();
        allow create, delete: if isSignedIn() && request.auth.uid == followerId;
      }

      // Takip edilenler — yalnızca profil sahibi yönetir
      match /following/{targetId} {
        allow read: if isSignedIn();
        allow create, delete: if isOwner(userId);
      }

      // Takip istekleri — istek gönderen oluşturur; profil sahibi veya gönderen siler
      match /followRequests/{fromUid} {
        allow read: if isOwner(userId) || (isSignedIn() && request.auth.uid == fromUid);
        allow create: if isSignedIn() && request.auth.uid == fromUid;
        allow delete: if isOwner(userId) || (isSignedIn() && request.auth.uid == fromUid);
      }

      // Bildirimler — herhangi giriş yapmış kullanıcı oluşturabilir; okuma/güncelleme sahibe
      match /notifications/{notifId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if isSignedIn();
      }

      // Beğeniler — yalnızca profil sahibi
      match /likes/{postId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }

      // Koleksiyonlar — okuma herkese; yazma sahibe
      match /collections/{collectionId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }
    }

    // Postlar
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.auth.uid == request.resource.data.authorUid;
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.authorUid
        || onlyPostSocialCounters()
      );
      allow delete: if isSignedIn()
                    && request.auth.uid == resource.data.authorUid;

      match /likes/{uid} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == uid;
      }

      match /comments/{commentId} {
        allow read, create: if isSignedIn();
        allow delete: if isSignedIn()
                      && request.auth.uid == resource.data.authorUid;
      }
    }

    // Katalog kitap puanlamaları
    match /bookRatings/{itemId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();

      match /ratings/{userId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Katalog film puanlamaları
    match /movieRatings/{itemId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();

      match /ratings/{userId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Genel katalog yorumları
    match /globalContentComments/{itemId}/comments/{commentId} {
      allow read, create: if isSignedIn();
      allow delete: if isSignedIn()
                    && request.auth.uid == resource.data.authorUid;
    }
  }
}
