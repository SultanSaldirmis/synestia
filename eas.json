{
  "cli": {
    "version": ">= 18.5.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "cache": {
        "key": "gradle-deps-v1",
        "paths": [
          "~/.gradle/caches",
          "~/.gradle/wrapper"
        ]
      }
    }
  },
  "submit": {
    "production": {}
  }
}
