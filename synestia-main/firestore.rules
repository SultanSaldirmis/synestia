rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Kullanıcı Profilleri (users koleksiyonu)
    match /users/{userId} {
      // Herkes giriş yapmış olmak kaydıyla profilleri görebilir (Okuma izni)
      allow read: if request.auth != null;
      
      // Sadece profilin sahibi kendi bilgilerini değiştirebilir (Yazma/Güncelleme izni)
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Kullanıcının kendi altındaki "likes" koleksiyonu için izinler
      match /likes/{likeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // 2. Genel İçerikler (Kitap, Film, Müzik vb. eğer ayrı bir koleksiyondaysa)
    // Eğer tüm içeriklerin okunmasını istiyorsan:
    match /{document=**} {
      allow read: if request.auth != null;
      // Admin paneli yapmayacağımız için genel yazma iznini kısıtlıyoruz
      allow write: if request.auth != null; 
    }
  }
}