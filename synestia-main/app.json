{
  "expo": {
    "name": "Synestia",
    "slug": "synestia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.synestia.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#121212"
      },
      "package": "com.synestia.app"
    },
    "scheme": "synestia",
    "plugins": [
      "expo-asset"
    ],
    "extra": {
      "firebase": {
        "apiKey": "",
        "authDomain": "",
        "projectId": "",
        "storageBucket": "",
        "messagingSenderId": "",
        "appId": ""
      },
      "tmdbApiKey": "",
      "spotifyClientId": "",
      "spotifyClientSecret": "",
      "eas": {
        "projectId": "5f16c01f-b21b-4ee6-81e0-7b6ccc1216cc"
      }
    }
  }
}
