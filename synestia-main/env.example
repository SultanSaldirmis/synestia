# Kopyalayıp proje kökünde `.env` olarak kaydedin (Synestia klasörü ile aynı yerde app.json / app.config.js olsun).
# `app.config.js` dotenv ile bu dosyayı yükler ve değerleri `expo.extra` üzerinden uygulamaya verir.
# Değişiklikten sonra: `npm install` ardından `npx expo start -c`

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# TMDB (Film araması)
EXPO_PUBLIC_TMDB_API_KEY=

# Spotify (Müzik araması)
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=
EXPO_PUBLIC_SPOTIFY_CLIENT_SECRET=
